# Environment
VITE_ENVIRONMENT_MODE=local

# Optional favicon overrides via API
# VITE_FAVICON_API_URL=
# VITE_FAVICON_RESPONSE_PATH=data.favicon
# VITE_FAVICON_CACHE_TTL_MS=

# API base (required). Vite only exposes vars prefixed with VITE_.
# VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=https://api.zbc.maktechlaravel.cloud/api/v1

# ─── Reverb / WebSocket (browser connects directly to the WS server) ──────────
# VITE_REVERB_APP_KEY MUST equal REVERB_APP_KEY in reverb_server and reverb_backend.
# Production values:
#   VITE_REVERB_HOST=ws.reverb.maktechlaravel.cloud
#   VITE_REVERB_PORT=443
#   VITE_REVERB_SCHEME=https
# Local (reverb running on host):
#   VITE_REVERB_HOST=localhost  VITE_REVERB_PORT=8080  VITE_REVERB_SCHEME=http
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=ws.zbc.maktechlaravel.cloud
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Auth strategy: bearer_memory | http_only_cookie
VITE_AUTH_STRATEGY=bearer_memory

# Bearer token storage: local (cross-tab) | session (tab-only) | memory
VITE_BEARER_TOKEN_STORAGE=local

VITE_AUTH_ME_PATH=/auth/profile
VITE_AUTH_LOGOUT_PATH=/auth/logout

# Role parsing: single (user.role) | multi (user.roles[])
# VITE_ROLE_MODE=single

# Optional role policy overrides (JSON). Example:
# VITE_ROLE_POLICY_JSON={"admin":{"dashboard":"/admin","fallback":"/admin/login"}}

# Login pages: single | multi
# VITE_LOGIN_MODE=single

# Logout mode: single | multi
# VITE_LOGOUT_MODE=single

# Optional refresh token flow
# VITE_REFRESH_TOKEN_ENABLED=false
# VITE_AUTH_REFRESH_PATH=/oauth/token
# VITE_REFRESH_TOKEN_BODY_KEY=refresh_token
